# Copy to .env.local and fill in.

# REQUIRED — Google Gemini API key (embeddings, generation, rerank, evaluate, image vision).
GEMINI_API_KEY=

# OPTIONAL — OpenAI key; cross-provider chat fallback if Gemini is unavailable.
OPENAI_API_KEY=

# OPTIONAL — override the Gemini chat model fallback chain (comma-separated).
# GEMINI_CHAT_MODELS=gemini-flash-lite-latest,gemini-3.1-flash-lite,gemini-flash-latest

# OPTIONAL — gate the lab behind an unlock code.
# RAG_ACCESS_CODE=
